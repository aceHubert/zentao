{
  "name": "zentao",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "typecheck": "lerna run typecheck --stream --scope '@acehubert/*'",
    "build": "lerna run build --stream --scope '@acehubert/*'",
    "test": "lerna run test --stream --scope '@acehubert/*'",
    "release": "lerna publish",
    "release:git": "lerna publish from-git",
    "release:package": "lerna publish from-package",
    "release:alpha": "lerna publish --conventional-commits --conventional-prerelease --preid alpha --dist-tag alpha",
    "release:next": "lerna publish --conventional-commits --conventional-prerelease --preid next --dist-tag next",
    "release:graduate": "lerna publish --conventional-commits --conventional-graduate",
    "changelog": "node ./scripts/genChangelog.js",
    "prepublishOnly": "yarn install --mode=skip-build && yarn changelog && yarn build && yarn test",
    "lint": "lerna run lint --stream --scope '@acehubert/*'",
    "lint:fix": "lerna run lint:fix --stream --scope '@acehubert/*'",
    "commit": "git-cz"
  },
  "devDependencies": {
    "@babel/runtime": "^7.28.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@instructure/cz-lerna-changelog": "^8.56.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "commitizen": "^4.3.1",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "lerna": "^8.2.1",
    "lerna-changelog": "^2.2.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "yorkie": "^2.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@instructure/cz-lerna-changelog"
    }
  },
  "gitHooks": {
    "commit-msg": "commitlint -e -V",
    "pre-commit": "lint-staged"
  },
  "ts-node": {
    "esm": true,
    "experimentalResolver": true,
    "experimentalSpecifierResolution": "node"
  },
  "packageManager": "yarn@3.2.0",
  "workspaces": [
    "packages/*"
  ]
}
